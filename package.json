{
  "name": "knowledge-platform",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npx concurrently -n api,web -c blue,green \"node scripts/dev-api.mjs\" \"node scripts/dev-web.mjs\"",
    "dev:turbo": "cross-env NEXT_TURBOPACK_DEV=1 npx concurrently -n api,web -c blue,green \"node scripts/dev-api.mjs\" \"node scripts/dev-web.mjs\"",
    "clean:web": "node scripts/clean-web-next.mjs",
    "dev:clean": "node scripts/clean-web-next.mjs && npm run dev",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "build": "npm run build -w @knowledge-platform/api && npm run build -w @knowledge-platform/web",
    "verify": "npm run build -w @knowledge-platform/api && npm run build -w @knowledge-platform/web",
    "analyze:web": "cross-env ANALYZE=true npm run build -w @knowledge-platform/web",
    "test:api": "npm run test -w @knowledge-platform/api",
    "eval:rag": "npm run eval:rag -w @knowledge-platform/api",
    "eval:rag:quick": "npm run eval:rag:quick -w @knowledge-platform/api",
    "eval:rag:baseline": "npm run eval:rag:baseline -w @knowledge-platform/api",
    "reindex:doc": "npm run reindex:doc -w @knowledge-platform/api",
    "reindex:all": "npm run reindex:all -w @knowledge-platform/api",
    "export:feedback": "npm run export:feedback -w @knowledge-platform/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run db:migrate -w @knowledge-platform/api",
    "db:generate": "npm run db:generate -w @knowledge-platform/api",
    "db:seed": "npm run db:seed -w @knowledge-platform/api",
    "lint": "npm run lint -w @knowledge-platform/web && npx tsc --noEmit -p apps/api/tsconfig.json",
    "lint:api": "npx eslint apps/api/src --config apps/api/eslint.config.mjs",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "prettier": "3.8.2"
  }
}
