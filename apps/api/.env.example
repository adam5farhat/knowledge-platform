DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_platform?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3001

# Public base URL of this API (scheme + host, no trailing slash). Must match what browsers use for
# <img src> on stored profile picture URLs. In production set to e.g. https://api.example.com
# (same origin you put in the web app as NEXT_PUBLIC_API_URL). Local dev: http://localhost:3001
PUBLIC_API_URL="http://localhost:3001"

# Auth (required; use a long random string in production)
JWT_SECRET="replace-with-at-least-16-random-characters"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_TTL_DAYS="30"

# Access tokens include authVersion; after password change or email change, old tokens stop working until you sign in again.

# Base URL of the web app (password reset links)
WEB_APP_URL="http://localhost:3000"

# Optional SMTP — if unset, forgot-password logs the reset link in dev (NODE_ENV !== production)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Knowledge Platform <noreply@example.com>"

# Seed script (optional overrides)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
# SEED_UX_DEPARTMENT_NAME="ui/ux"
# SEED_BACKOFFICE_DEPARTMENT_NAME="backoffice"
# SEED_MANAGER_EMAIL="manager@example.com"
# SEED_MANAGER_PASSWORD="ChangeMe123!"
# SEED_MANAGER_NAME="Backoffice Manager"
# SEED_MANAGER_DEPARTMENT_NAME="backoffice"
# SEED_MANAGER_POSITION="Team lead"
# SEED_UX_EMPLOYEE_EMAIL="ux.employee@example.com"
# SEED_UX_EMPLOYEE_PASSWORD="ChangeMe123!"
# SEED_UX_EMPLOYEE_NAME="UI/UX Employee"
# SEED_UX_EMPLOYEE_BADGE="UX-1001"
# SEED_UX_EMPLOYEE_POSITION="Designer"

# Document storage (defaults to apps/api/storage/uploads when running from api package)
# STORAGE_PATH="C:\\path\\to\\uploads"

# OpenAI — required for ingest (embeddings) and /search/semantic
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Chunking (optional)
# CHUNK_SIZE_CHARS=1800
# CHUNK_OVERLAP_CHARS=200
