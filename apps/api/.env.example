DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_platform?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3001

# Auth (required; use a long random string in production)
JWT_SECRET="replace-with-at-least-16-random-characters"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_TTL_DAYS="30"

# Access tokens include authVersion; after password change or email change, old tokens stop working until you sign in again.

# Base URL of the web app (password reset links)
WEB_APP_URL="http://localhost:3000"

# Optional SMTP — if unset, forgot-password logs the reset link in dev (NODE_ENV !== production)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Knowledge Platform <noreply@example.com>"

# Seed script (optional overrides)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Document storage (defaults to apps/api/storage/uploads when running from api package)
# STORAGE_PATH="C:\\path\\to\\uploads"

# OpenAI — required for ingest (embeddings) and /search/semantic
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Chunking (optional)
# CHUNK_SIZE_CHARS=1800
# CHUNK_OVERLAP_CHARS=200
