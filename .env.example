# Copy to apps/api/.env and apps/web/.env.local (or use root .env loaded by api)

# PostgreSQL (matches docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_platform?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
PORT=3001
JWT_SECRET="replace-with-at-least-32-random-characters!"
JWT_EXPIRES_IN="15m"

# Web — browser-visible API base (must match PUBLIC_API_URL on the API, same scheme + host)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# API — canonical URL for absolute links (e.g. avatar URLs). Copy into apps/api/.env; must match NEXT_PUBLIC_API_URL above.
# PUBLIC_API_URL="http://localhost:3001"

# Password reset links (set on API — apps/api/.env)
# WEB_APP_URL="http://localhost:3000"

# Google Gemini — required for document ingest (embeddings) and /search/ask RAG pipeline
# GEMINI_API_KEY=""
# GEMINI_CHAT_MODEL="gemini-2.5-flash"
# GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
